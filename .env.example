# AgentFlow Environment Configuration
# Copy to .env and customize. Scripts source this automatically.
# Precedence: command-line flags > env vars > .env > defaults

# MongoDB (external server at afl-mongodb, defined in /etc/hosts)
AFL_MONGODB_URL=mongodb://afl-mongodb:27017
AFL_MONGODB_DATABASE=afl
AFL_EXAMPLES_DATABASE=afl_examples

# Scaling
AFL_RUNNERS=2
AFL_AGENTS=2
AFL_OSM_AGENTS=2
AFL_OSM_LITE_AGENTS=2
AFL_WEATHER_AGENTS=2

# Runner tuning
# AFL_MAX_CONCURRENT=2
# AFL_POLL_INTERVAL_MS=1000
# AFL_REAPER_TIMEOUT_MS=120000   # Orphan reaper timeout (default 2min)
# AFL_STUCK_TIMEOUT_MS=1800000   # Stuck task watchdog timeout (default 30min)
# AFL_TASK_EXECUTION_TIMEOUT_MS=900000  # Per-task execution timeout (default 15min)
# AFL_LEASE_DURATION_MS=300000   # Task lease duration (default 5min; renewed by heartbeat)

# Overlays
AFL_HDFS=false
AFL_POSTGIS=false
# AFL_POSTGIS_URL=postgresql://afl:afl@afl-postgres:5432/afl_gis
AFL_JENKINS=false
AFL_GEOFABRIK_MIRROR=/Volumes/afl_data/osm

# Base output directory for all handler output (default: /Volumes/afl_data/output)
# All example categories derive subdirectories from this (osm/, hiv-reports/, weather/, etc.)
# Temporary files also go under AFL_OUTPUT_BASE/tmp/ instead of /tmp.
# AFL_OUTPUT_BASE=/Volumes/afl_data/output

# Legacy alias for AFL_OUTPUT_BASE (backward compatibility)
# AFL_LOCAL_OUTPUT_DIR=/Volumes/afl_data/output

# OSM cache directory (HDFS URI or local path; empty = AFL_OUTPUT_BASE/cache/osm)
# AFL_CACHE_DIR=hdfs://afl-hadoop-hdfs:8020/osm-cache
# AFL_CACHE_DIR=/Volumes/afl_data/osm-cache

# OSM extractor output base (HDFS URI or local path; empty = AFL_OUTPUT_BASE/osm)
# AFL_OSM_OUTPUT_BASE=hdfs://afl-hadoop-hdfs:8020/osm-output
# AFL_OSM_OUTPUT_BASE=/Volumes/afl_data/output/osm

# LLM (Claude API for prompt-block event facets)
# ANTHROPIC_API_KEY=

# Remote runner management
# AFL_RUNNER_HOSTS=host1 host2 host3
# AFL_REMOTE_PATH=/opt/agentflow
# AFL_SSH_OPTS=

# External data dirs (leave empty for Docker volumes)
# HDFS_NAMENODE_DIR=
# HDFS_DATANODE_DIR=
# GRAPHHOPPER_DATA_DIR=
# POSTGIS_DATA_DIR=
# JENKINS_HOME_DIR=
