        {
          "type": "EventFacetDecl",
          "name": "DownloadOpenLitterMap",
          "doc": {
            "description": "Download OpenLitterMap geotagged litter observations.\n\n``mode = \"clusters\"`` (default) works at any zoom; returns\naggregated cluster points. ``mode = \"points\"`` returns\nindividual photos but the upstream server enforces\n``zoom >= 15`` and a bounded ``bbox``.\n\n``bbox`` is a comma-separated ``min_lon,min_lat,max_lon,max_lat``\nstring (empty = no bbox). Keeping it a String avoids making\nJson mandatory; handlers parse it at dispatch time.",
            "params": [],
            "returns": []
          },
          "params": [
            {
              "name": "mode",
              "type": "String",
              "default": {
                "type": "String",
                "value": "clusters"
              }
            },
            {
              "name": "zoom",
              "type": "Int",
              "default": {
                "type": "Int",
                "value": 4
              }
            },
            {
              "name": "bbox",
              "type": "String",
              "default": {
                "type": "String",
                "value": ""
              }
            },
            {
              "name": "force",
              "type": "Boolean",
              "default": {
                "type": "Boolean",
                "value": false
              }
            },
            {
              "name": "use_mock",
              "type": "Boolean",
              "default": {
                "type": "Boolean",
                "value": false
              }
            }
          ],
          "returns": [
            {
              "name": "cache_type",
              "type": "String"
            },
            {
              "name": "relative_path",
              "type": "String"
            },
            {
              "name": "feature_count",
              "type": "Int"
            },
            {
              "name": "size_bytes",
              "type": "Int"
            },
            {
              "name": "sha256",
              "type": "String"
            },
            {
              "name": "source_url",
              "type": "String"
            },
            {
              "name": "was_cached",
              "type": "Boolean"
            },
            {
              "name": "used_mock",
              "type": "Boolean"
            }
          ],
          "mixins": [
            {
              "type": "MixinSig",
              "target": "RetryPolicy"
            }
          ],
          "id": "ae90b1ba-d22b-4ae3-90c8-a795c9d74ff8",
