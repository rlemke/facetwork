          "doc": {
            "description": "Download every source and build the combined global map.\n\nDownloads run in parallel (FFL ``andThen`` siblings are\nscheduled concurrently when they don't reference each other).\nAny download failure yields ``partial_failure`` with a\ndescribing ``detail`` but does not stop the map build \u2014 the\nmap-render tool skips absent layers gracefully.",
            "params": [],
            "returns": []
          },
          "params": [
