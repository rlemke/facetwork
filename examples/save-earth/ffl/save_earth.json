    {
      "type": "Namespace",
      "name": "save_earth.maps",
      "uses": [
        "save_earth.types"
      ],
      "declarations": [
        {
          "type": "EventFacetDecl",
          "name": "BuildMap",
          "doc": {
            "description": "Build a MapLibre HTML map with every cached save-earth layer.\n\nAuto-discovers cached files \u2014 every OpenLitterMap GeoJSON under\n``cache/save-earth/openlittermap/`` and every EPA dataset\nbecomes its own toggleable layer. Passing a dependency signal\n(e.g. the ``feature_count`` from a just-finished download) lets\nthe runtime sequence the map build after the downloads it\nrelies on.\n\n``basemap_url`` / ``basemap_attribution`` let the caller swap\nthe raster basemap. Default is CARTO Voyager \u2014 free, no API\nkey, works from ``file://`` (unlike tile.openstreetmap.org,\nwhich requires a Referer header per its volunteer-tile\npolicy). Supports ``{z}/{x}/{y}`` plus optional ``{s}`` for\nsubdomain rotation.",
            "params": [],
            "returns": []
          },
          "params": [
            {
              "name": "region",
              "type": "String",
              "default": {
                "type": "String",
                "value": "global"
              }
            },
            {
              "name": "center_lat",
              "type": "Double",
              "default": {
                "type": "Double",
                "value": 39.8283
              }
            },
            {
              "name": "center_lon",
              "type": "Double",
              "default": {
                "type": "UnaryExpr",
                "operator": "-",
                "operand": {
                  "type": "Double",
                  "value": 98.5795
                }
              }
            },
            {
              "name": "zoom",
              "type": "Double",
              "default": {
                "type": "Double",
                "value": 4.0
              }
            },
            {
              "name": "basemap_url",
              "type": "String",
              "default": {
                "type": "String",
                "value": ""
              }
            },
            {
              "name": "basemap_attribution",
              "type": "String",
              "default": {
                "type": "String",
                "value": ""
              }
            },
            {
              "name": "dependency_signal",
              "type": "Int",
              "default": {
                "type": "Int",
                "value": 0
              }
            }
          ],
          "returns": [
            {
              "name": "region_key",
              "type": "String"
            },
            {
              "name": "output_dir",
              "type": "String"
            },
            {
              "name": "html_path",
              "type": "String"
            },
            {
              "name": "layer_count",
              "type": "Int"
            },
            {
              "name": "layer_counts",
              "type": "Json"
            }
          ],
          "id": "f4987abc-b598-4a47-bc50-a7476466cbe9",
          "location": {
            "line": 129,
            "column": 5,
            "endLine": 159,
            "endColumn": 1
          }
        }
      ],
