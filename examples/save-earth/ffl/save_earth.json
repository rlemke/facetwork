          "type": "EventFacetDecl",
          "name": "BuildMap",
          "doc": {
            "description": "Build a MapLibre HTML map with every cached save-earth layer.\n\nAuto-discovers cached files \u2014 you don't have to list every\nlayer up-front. Passing a dependency signal (e.g. the\n``feature_count`` from a just-finished download) lets the\nruntime sequence the map build after the downloads it\nrelies on.",
            "params": [],
            "returns": []
          },
          "params": [
            {
              "name": "region",
              "type": "String",
              "default": {
                "type": "String",
                "value": "global"
              }
            },
            {
              "name": "center_lat",
              "type": "Double",
              "default": {
                "type": "Double",
                "value": 39.8283
              }
            },
            {
              "name": "center_lon",
              "type": "Double",
              "default": {
                "type": "UnaryExpr",
                "operator": "-",
                "operand": {
                  "type": "Double",
                  "value": 98.5795
                }
              }
            },
            {
              "name": "zoom",
              "type": "Double",
              "default": {
                "type": "Double",
                "value": 4.0
              }
            },
            {
              "name": "dependency_signal",
              "type": "Int",
              "default": {
                "type": "Int",
                "value": 0
              }
            }
          ],
          "returns": [
            {
              "name": "region_key",
              "type": "String"
            },
            {
              "name": "output_dir",
              "type": "String"
            },
            {
              "name": "html_path",
              "type": "String"
            },
            {
              "name": "layer_count",
              "type": "Int"
            },
            {
              "name": "layer_counts",
              "type": "Json"
            }
          ],
          "id": "baff773e-748c-4687-a550-60bf9975a1c6",
          "location": {
