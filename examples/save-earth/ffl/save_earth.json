        {
          "type": "EventFacetDecl",
          "name": "DownloadTri",
          "doc": {
            "description": "Download the EPA Toxic Release Inventory facility table.\n\nFetches TRI_FACILITY from ``data.epa.gov/efservice/`` (the\nold ``enviro.epa.gov`` URL redirects there). ~65 k rows\ntotal, paginated at 10 k/request. Normalizes longitude sign\nfor western-hemisphere state codes.\n\n``active_only`` (default true) drops facilities whose\n``fac_closed_ind`` is ``\"1\"``.",
            "params": [],
            "returns": []
          },
          "params": [
            {
              "name": "active_only",
              "type": "Boolean",
              "default": {
                "type": "Boolean",
                "value": true
              }
            },
            {
