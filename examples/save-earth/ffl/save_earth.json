              "name": "include_brownfields",
              "type": "Boolean",
              "default": {
                "type": "Boolean",
                "value": true
              }
            },
            {
              "name": "use_mock",
              "type": "Boolean",
              "default": {
                "type": "Boolean",
                "value": false
              }
            }
          ],
