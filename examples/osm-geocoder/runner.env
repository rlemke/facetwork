# Runner environment for osm-geocoder example.
#
# These variables are sourced by scripts/start-runner when --example osm-geocoder
# is specified. They override the global defaults in .env for this example only.
#
# PostGIS imports can take hours for large regions (e.g., California 1.2GB PBF).
# The default 15-minute execution timeout kills imports before they complete.
# Heartbeats fire during the osmium scan phase but cannot fire during blocking
# PostgreSQL UPSERT calls, so the timeout must accommodate the longest possible
# single-batch DB write.
AFL_TASK_EXECUTION_TIMEOUT_MS=14400000   # 4 hours
AFL_STUCK_TIMEOUT_MS=14400000            # 4 hours (must match execution timeout)

# Local-first PostGIS import: parse PBF into a disposable local PG instance,
# then bulk-transfer to the main server. Reduces I/O load on main PG during
# multi-hour imports. Start with: scripts/start-import-pg
# AFL_IMPORT_POSTGIS_URL=postgresql://afl_osm:afl_osm_2024@localhost:5433/osm
