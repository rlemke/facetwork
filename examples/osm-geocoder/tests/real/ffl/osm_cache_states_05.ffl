/** Downloads OSM PBF caches for 5 US states in parallel. */
namespace osm.UnitedStates.cache {
  use osm.types
  use osm.ops
  use osm.cache.UnitedStates

  /** Fetches and aggregates OSM cache data for 5 US states. */
  workflow DownloadStates_05() => (cache: [OSMCache]) andThen {
    alabama = Alabama()
    alaska = Alaska()
    arizona = Arizona()
    arkansas = Arkansas()
    california = California()
    yield DownloadStates_05(cache = alabama.cache ++ alaska.cache ++ arizona.cache ++ arkansas.cache ++ california.cache)
  }

}
