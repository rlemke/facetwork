// ML Hyperparameter Sweep
//
// Demonstrates: statement-level andThen, prompt blocks, map literals,
// andThen foreach, mixins, implicits, pre-scripts, andThen scripts,
// arithmetic, collection literals, schemas, doc comments.

// -----------------------------------------------------------------------
// Types
// -----------------------------------------------------------------------
/** Shared type definitions for ML hyperparameter sweep. */
namespace ml.types {
    /** Metadata describing a prepared dataset. */
    schema DatasetInfo {
        name: String,
        num_features: Long,
        num_samples: Long,
        feature_names: Json,
        file_path: String,
        labels_path: String
    }

    /** Configuration for train/validation/test data splitting. */
    schema SplitConfig {
        train_ratio: Double,
        val_ratio: Double,
        test_ratio: Double,
        stratified: Boolean,
        random_seed: Long
    }

    /** Training hyperparameters for a single sweep configuration. */
    schema HyperParams {
        learning_rate: Double,
        epochs: Long,
        batch_size: Long,
        dropout: Double,
        optimizer: String
    }

    /** Results from a single training run including loss and accuracy. */
    schema TrainResult {
        model_id: String,
        run_label: String,
        final_loss: Double,
        accuracy: Double,
        training_time_s: Long,
        hyperparams: Json
    }

    /** Model evaluation metrics on the test set. */
    schema EvalResult {
        model_id: String,
        accuracy: Double,
        precision: Double,
        recall: Double,
        f1_score: Double,
        confusion_matrix: Json
    }

    /** Comparison of models with ranking and best model selection. */
    schema ComparisonResult {
        best_model_id: String,
        metric_name: String,
        ranking: Json,
        summary: String
    }

    /** Summary report of a completed hyperparameter sweep. */
    schema SweepReport {
        dataset_name: String,
        total_configs: Long,
        summary_text: String,
        timestamp: String,
        best_config: Json
    }

    /** Neural network architecture configuration. */
    schema ModelConfig {
        model_type: String,
        hidden_layers: Json,
        activation: String
    }
}

// -----------------------------------------------------------------------
// Mixins
// -----------------------------------------------------------------------
/** Cross-cutting mixins and implicit defaults for training runs. */
namespace ml.mixins {
    /** Retry policy with configurable attempts and backoff. */
    facet Retry(max_attempts: Int = 3, backoff_ms: Int = 1000)
    /** Maximum execution time for a training step. */
    facet Timeout(minutes: Int = 60)
    /** GPU device assignment and memory allocation. */
    facet GPU(device_id: Int = 0, memory_fraction: Double = 0.9)
    /** Experiment tracking integration for run logging. */
    facet ExperimentTracker(run_name: String, project: String = "hyperparam-sweep")

    implicit defaultRetry = Retry(max_attempts = 3, backoff_ms = 1000)
    implicit defaultTimeout = Timeout(minutes = 60)
    implicit defaultGPU = GPU(device_id = 0, memory_fraction = 0.9)
}

// -----------------------------------------------------------------------
// Data
// -----------------------------------------------------------------------
/** Dataset preparation and splitting. */
namespace ml.Data {
    use ml.types

    /** Prepare a synthetic dataset for training. */
    event facet PrepareDataset(
        dataset_name: String = "synthetic",
        num_features: Long = 10,
        num_samples: Long = 1000
    ) => (dataset: DatasetInfo)

    /** Split dataset into train/val/test partitions. */
    event facet SplitDataset(
        dataset: DatasetInfo,
        config: Json
    ) => (
        train_path: String,
        val_path: String,
        test_path: String,
        train_count: Long,
        val_count: Long,
        test_count: Long
    )
}

// -----------------------------------------------------------------------
// Training
// -----------------------------------------------------------------------
/** Model training with configurable hyperparameters. */
namespace ml.Training {
    use ml.types

    /** Train a model with given hyperparameters. */
    event facet TrainModel(
        dataset_name: String,
        train_path: String,
        val_path: String,
        hyperparams: Json,
        model_config: Json,
        run_label: String = "run"
    ) => (result: TrainResult)
}

// -----------------------------------------------------------------------
// Evaluation
// -----------------------------------------------------------------------
/** Model evaluation and comparison. */
namespace ml.Evaluation {
    use ml.types

    /** Evaluate a trained model on the test set. */
    event facet EvaluateModel(
        model_id: String,
        test_path: String
    ) => (result: EvalResult)

    /** Compare evaluation results and select the best model. */
    event facet CompareToBestModel(
        eval_results: Json,
        metric_name: String = "f1_score"
    ) => (comparison: ComparisonResult)
}

// -----------------------------------------------------------------------
// Reporting
// -----------------------------------------------------------------------
/** LLM-powered sweep report generation. */
namespace ml.Reporting {
    use ml.types

    /** Generate a human-readable sweep report using an LLM. */
    event facet GenerateSweepReport(
        dataset_name: String,
        comparison: ComparisonResult,
        sweep_config: Json
    ) => (report: SweepReport) prompt {
        system "You are an ML engineer writing concise experiment reports."
        template "Summarize the hyperparameter sweep for dataset {dataset_name}. The best model was {comparison.best_model_id} with metric {comparison.metric_name}. Sweep config: {sweep_config}."
        model "claude-sonnet-4-20250514"
    }
}

// -----------------------------------------------------------------------
// Workflows
// -----------------------------------------------------------------------
/** Top-level hyperparameter sweep workflows. */
namespace ml.workflows {
    use ml.types
    use ml.mixins
    use ml.Data
    use ml.Training
    use ml.Evaluation
    use ml.Reporting

    /** Run a hyperparameter sweep over four configurations with per-run evaluation. */
    workflow HyperparamSweep(
        dataset_name: String = "synthetic",
        num_features: Long = 10,
        num_samples: Long = 1000,
        learning_rates: Json = "[0.001, 0.01, 0.05, 0.1]"
    ) => (
        best_model: ComparisonResult,
        report: SweepReport,
        total_runs: Long,
        grid_description: String
    ) script {
        result["total_runs"] = 4
        result["grid_description"] = "4 learning rates x 1 config = " + str(4) + " total runs"
    } andThen {
        prep = PrepareDataset(dataset_name = $.dataset_name, num_features = $.num_features, num_samples = $.num_samples)
        split = SplitDataset(dataset = prep.dataset, config = #{"train_ratio": 0.7, "val_ratio": 0.15, "test_ratio": 0.15, "stratified": true, "random_seed": 42})
        t0 = TrainModel(
            dataset_name = $.dataset_name,
            train_path = split.train_path,
            val_path = split.val_path,
            hyperparams = #{"learning_rate": 0.001, "epochs": 50, "batch_size": 32, "dropout": 0.3, "optimizer": "adam"},
            model_config = #{"model_type": "mlp", "hidden_layers": "[128, 64]", "activation": "relu"},
            run_label = "lr_0.001"
        ) with Timeout(minutes = 30) with GPU(device_id = 0) andThen {
            e0 = EvaluateModel(model_id = t0.result.model_id, test_path = split.test_path)
        }
        t1 = TrainModel(
            dataset_name = $.dataset_name,
            train_path = split.train_path,
            val_path = split.val_path,
            hyperparams = #{"learning_rate": 0.01, "epochs": 50, "batch_size": 32, "dropout": 0.3, "optimizer": "adam"},
            model_config = #{"model_type": "mlp", "hidden_layers": "[128, 64]", "activation": "relu"},
            run_label = "lr_0.01"
        ) with Timeout(minutes = 30) with GPU(device_id = 0) andThen {
            e1 = EvaluateModel(model_id = t1.result.model_id, test_path = split.test_path)
        }
        t2 = TrainModel(
            dataset_name = $.dataset_name,
            train_path = split.train_path,
            val_path = split.val_path,
            hyperparams = #{"learning_rate": 0.05, "epochs": 50, "batch_size": 32, "dropout": 0.2, "optimizer": "adam"},
            model_config = #{"model_type": "mlp", "hidden_layers": "[128, 64]", "activation": "relu"},
            run_label = "lr_0.05"
        ) with Timeout(minutes = 30) with GPU(device_id = 1) andThen {
            e2 = EvaluateModel(model_id = t2.result.model_id, test_path = split.test_path)
        }
        t3 = TrainModel(
            dataset_name = $.dataset_name,
            train_path = split.train_path,
            val_path = split.val_path,
            hyperparams = #{"learning_rate": 0.1, "epochs": 50, "batch_size": 64, "dropout": 0.1, "optimizer": "sgd"},
            model_config = #{"model_type": "mlp", "hidden_layers": "[256, 128, 64]", "activation": "relu"},
            run_label = "lr_0.1"
        ) with Timeout(minutes = 30) with GPU(device_id = 1) andThen {
            e3 = EvaluateModel(model_id = t3.result.model_id, test_path = split.test_path)
        }
        best = CompareToBestModel(eval_results = [e0.result, e1.result, e2.result, e3.result], metric_name = "f1_score")
        rpt = GenerateSweepReport(dataset_name = $.dataset_name, comparison = best.comparison, sweep_config = #{"num_configs": 4, "model_type": "mlp", "varied_param": "learning_rate"})
        yield HyperparamSweep(best_model = best.comparison, report = rpt.report)
    } andThen script {
        result["grid_description"] = (
            "Sweep complete: " + str(params.get("total_runs", 4))
            + " configurations evaluated for dataset "
            + params.get("dataset_name", "synthetic")
        )
    }

    /** Dynamic grid search using foreach to fan out over configurations. */
    workflow GridSearchSweep(
        dataset_name: String = "synthetic",
        num_features: Long = 10,
        num_samples: Long = 500,
        configs: Json = "[]"
    ) => (
        dataset: DatasetInfo,
        train_path: String,
        test_path: String
    ) andThen {
        prep = PrepareDataset(dataset_name = $.dataset_name, num_features = $.num_features, num_samples = $.num_samples) with Retry(max_attempts = 3, backoff_ms = 2000)
        split = SplitDataset(dataset = prep.dataset, config = #{"train_ratio": 0.8, "val_ratio": 0.1, "test_ratio": 0.1, "stratified": false, "random_seed": 99})
        yield GridSearchSweep(dataset = prep.dataset, train_path = split.train_path, test_path = split.test_path)
    } andThen foreach cfg in $.configs {
        run = TrainModel(dataset_name = $.dataset_name, train_path = $.cfg.train_path, val_path = $.cfg.val_path, hyperparams = $.cfg.hyperparams, model_config = #{"model_type": "mlp", "hidden_layers": "[64, 32]", "activation": "tanh"}, run_label = "grid") with Timeout(minutes = 45) andThen {
            ev = EvaluateModel(model_id = run.result.model_id, test_path = $.cfg.test_path)
        }
        yield GridSearchSweep(train_path = ev.result.model_id)
    }
}
