    workflow CacheRussiaData(max_stations: Int = 5, start_year: Int = 1944, end_year: Int = 2026) => (status: String) andThen {
        cache = CacheStateData(country = "RS", state = "", max_stations = $.max_stations, start_year = $.start_year, end_year = $.end_year)
        yield CacheRussiaData(status = "completed")
