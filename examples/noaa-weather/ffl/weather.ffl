    /** Cache GHCN-Daily data for 3 Arctic territories. */
    workflow CacheArcticData(countries: [String] = ["GL","SV","IC"], max_stations: Int = 3, start_year: Int = 1944, end_year: Int = 2026) => (status: String = "completed") andThen foreach country in $.countries {
        cache = CacheStateData(country = $.country, state = "", max_stations = $.max_stations, start_year = $.start_year, end_year = $.end_year) catch {
