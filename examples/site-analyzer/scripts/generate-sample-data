#!/usr/bin/env bash
# Generate sample HTML files for the site-analyzer pipeline.
#
# Creates sample pages simulating a small website at /tmp/site-analyzer/:
#   homepage.html     — landing page with hero section
#   blog-post.html    — blog article about distributed systems
#   docs-api.html     — API documentation page
#   about.html        — company about page
#   pricing.html      — product pricing page
#   404.html          — error page
#
# Usage:
#   examples/site-analyzer/scripts/generate-sample-data

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
EXAMPLE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PYTHON="${REPO_ROOT}/.venv/bin/python3"
[[ -x "$PYTHON" ]] || PYTHON=python3
OUTPUT_DIR="/tmp/site-analyzer"

echo "Generating sample HTML pages in ${OUTPUT_DIR}/ ..."

env PYTHONPATH="$REPO_ROOT:$EXAMPLE_DIR" "$PYTHON" - "$OUTPUT_DIR" <<'PYEOF'
import os
import sys

output_dir = sys.argv[1]
os.makedirs(output_dir, exist_ok=True)

pages = {
    "homepage.html": """<!DOCTYPE html>
