for filename, content in pages.items():
    path = os.path.join(output_dir, filename)
    with open(path, "w") as f:
        f.write(content.strip() + "\n")
    size_kb = os.path.getsize(path) / 1024
    print(f"  {filename:25s} ({size_kb:.1f} KB)")

print(f"\nGenerated {len(pages)} sample HTML pages in {output_dir}/")
print(f"\nTo analyze the site:")
print(f"  Workflow: site.workflows.AnalyzeSite")
print(f'  Parameters: {{"urls": ["https://cloudflow.example.com/", "https://cloudflow.example.com/blog/resilient-workflows", "https://cloudflow.example.com/docs/api", "https://cloudflow.example.com/about", "https://cloudflow.example.com/pricing"]}}')
print(f"\nTo analyze a single page:")
print(f"  Workflow: site.workflows.AnalyzePage")
print(f'  Parameters: {{"url": "https://cloudflow.example.com/blog/resilient-workflows"}}')
PYEOF
