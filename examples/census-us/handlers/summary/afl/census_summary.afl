namespace census.Summary {
    use census.types

    event facet JoinGeo(acs_path: String, tiger_path: String, join_field: String = "GEOID", extra_acs_paths: List[String] = []) => (result: CensusSummary)

    event facet SummarizeState(population: ACSResult, income: ACSResult, housing: ACSResult, education: ACSResult, commuting: ACSResult, race: ACSResult = {}, poverty: ACSResult = {}, employment: ACSResult = {}) => (result: CensusSummary)
}
