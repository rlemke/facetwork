#!/usr/bin/env bash
# Stop the local mongod process started by scripts/start_mongo.
#
# Matches the specific mongod invocation (dbpath + bind_ip) so this won't
# touch an unrelated mongod on the same machine.
#
# Sends SIGTERM first (allows a clean WiredTiger checkpoint), waits for
# the process to exit, and falls back to SIGKILL only if the graceful
# shutdown does not finish in time. Use --force to SIGKILL immediately.
#
# Usage:
#   scripts/stop_mongo
#   scripts/stop_mongo --force    # SIGKILL without waiting
#   scripts/stop_mongo --timeout 60
#
set -uo pipefail

DBPATH="/Volumes/afl_data/local_servers/mongodb/data"
TIMEOUT=30
FORCE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --force)   FORCE=true; shift ;;
        --timeout) TIMEOUT="$2"; shift 2 ;;
        -h|--help)
            sed -n '2,/^set/{ /^#/s/^# \{0,1\}//p; }' "$0"
            exit 0 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

# Match mongod by dbpath to avoid hitting unrelated instances.
PIDS=$(pgrep -f "mongod .*--dbpath ${DBPATH}" || true)

if [[ -z "$PIDS" ]]; then
    echo "mongod (dbpath=$DBPATH) is not running."
    exit 0
fi

echo "Found mongod PIDs: $PIDS"

SIGNAL="TERM"
$FORCE && SIGNAL="KILL"

for pid in $PIDS; do
    echo "Sending SIG${SIGNAL} to $pid ..."
    kill -"$SIGNAL" "$pid" 2>/dev/null || true
done

$FORCE && { echo "Force-killed."; exit 0; }

# Wait for graceful shutdown
echo -n "Waiting up to ${TIMEOUT}s for clean shutdown"
for ((i=0; i<TIMEOUT; i++)); do
    still_running=false
    for pid in $PIDS; do
        if kill -0 "$pid" 2>/dev/null; then
            still_running=true
            break
        fi
    done
    if ! $still_running; then
        echo " — stopped."
        exit 0
    fi
    echo -n "."
    sleep 1
done

echo ""
echo "Graceful shutdown timed out. Escalating to SIGKILL." >&2
for pid in $PIDS; do
    if kill -0 "$pid" 2>/dev/null; then
        kill -KILL "$pid" 2>/dev/null || true
    fi
done
exit 1
