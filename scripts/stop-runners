#!/usr/bin/env bash
# Stop all running AFL runner and dashboard processes.
#
# Local mode (default): finds local processes via pgrep, sends SIGTERM,
# waits up to 5 seconds, then SIGKILL any survivors.
#
# Remote mode: queries MongoDB for running servers, SSHs to each host
# to send SIGTERM, polls MongoDB for SHUTDOWN state, force-kills if needed.
#
# Usage:
#   scripts/stop-runners                     # local mode (existing behavior)
#   scripts/stop-runners --all               # all remote servers from MongoDB
#   scripts/stop-runners --host h1 --host h2 # specific remote hosts
#   scripts/stop-runners --help              # show this help
#
# Remote options:
#   --all              Stop runners on all hosts found in MongoDB
#   --host HOST        Stop runners on specific host (repeatable)
#   --drain-timeout N  Seconds to wait for graceful drain (default: 30)
#
# Environment:
#   AFL_RUNNER_HOSTS   Space-separated hostnames (used with --all if set)
#   AFL_REMOTE_PATH    Repo path on remote hosts (default: same as local)
#   AFL_SSH_OPTS       Extra SSH options
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$(dirname "$0")/_env.sh"

MODE="local"
HOST_ARGS=()
DRAIN_TIMEOUT=30

while [[ $# -gt 0 ]]; do
    case "$1" in
        --all)
            MODE="remote"; shift ;;
        --host)
            MODE="remote"; HOST_ARGS+=("$2"); shift 2 ;;
        --drain-timeout)
            DRAIN_TIMEOUT="$2"; shift 2 ;;
        -h|--help)
            sed -n '2,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
            exit 0 ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1 ;;
    esac
done

# =========================================================================
# Local mode (original behavior)
# =========================================================================

if [[ "$MODE" == "local" ]]; then
    PATTERN='afl\.runtime\.runner|afl\.dashboard'

    PIDS=$(pgrep -f "$PATTERN" 2>/dev/null || true)

    if [[ -z "$PIDS" ]]; then
        echo "No runners or dashboard found."
        exit 0
    fi

    # Categorize for display
    RUNNER_PIDS=$(pgrep -f 'afl\.runtime\.runner' 2>/dev/null || true)
    DASH_PIDS=$(pgrep -f 'afl\.dashboard' 2>/dev/null || true)
    [[ -n "$RUNNER_PIDS" ]] && echo "Found runner PIDs: $RUNNER_PIDS"
    [[ -n "$DASH_PIDS" ]]   && echo "Found dashboard PIDs: $DASH_PIDS"

    echo "Sending SIGTERM..."
    kill $PIDS 2>/dev/null || true

    # Wait up to 5 seconds for graceful exit
    for i in $(seq 1 10); do
        REMAINING=$(pgrep -f "$PATTERN" 2>/dev/null || true)
        if [[ -z "$REMAINING" ]]; then
            echo "All processes stopped."
            exit 0
        fi
        sleep 0.5
    done

    # Force kill survivors
    REMAINING=$(pgrep -f "$PATTERN" 2>/dev/null || true)
    if [[ -n "$REMAINING" ]]; then
        echo "Processes still alive: $REMAINING — sending SIGKILL..."
        kill -9 $REMAINING 2>/dev/null || true
        echo "Done."
    else
        echo "All processes stopped."
    fi
    exit 0
fi

# =========================================================================
# Remote mode
# =========================================================================

source "$(dirname "$0")/_remote.sh"
_afl_resolve_remote_env

echo "=== AgentFlow: Stop Remote Runners ==="
echo ""

# Discover running servers from MongoDB
SERVERS=$(_afl_query_running_servers)

if [[ -z "$SERVERS" ]]; then
    echo "No running servers found in MongoDB."
    exit 0
fi

echo "Running servers in MongoDB:"
echo "$SERVERS" | while IFS= read -r line; do
    read -r name port uuid <<< "$line"
    echo "  $name (port=$port, id=$uuid)"
done
echo ""

# If --host specified, filter to those hosts
if [[ ${#HOST_ARGS[@]} -gt 0 ]]; then
    FILTERED=""
    for host in "${HOST_ARGS[@]}"; do
        MATCH=$(echo "$SERVERS" | grep "^${host} " || true)
        if [[ -n "$MATCH" ]]; then
            FILTERED="${FILTERED}${FILTERED:+$'\n'}${MATCH}"
        else
            echo "Warning: no running server found for host '$host'"
        fi
    done
    SERVERS="$FILTERED"
fi

if [[ -z "$SERVERS" ]]; then
    echo "No matching servers to stop."
    exit 0
fi

# Collect unique hostnames and send SIGTERM via SSH
UNIQUE_HOSTS=$(echo "$SERVERS" | awk '{print $1}' | sort -u)

PATTERN='afl\.runtime\.runner|afl\.dashboard'

while IFS= read -r host; do
    [[ -z "$host" ]] && continue
    echo "Sending SIGTERM to runners on $host..."
    _afl_ssh "$host" "pgrep -f '$PATTERN' | xargs kill 2>/dev/null || true" || {
        echo "  Warning: SSH to $host failed"
    }
done <<< "$UNIQUE_HOSTS"

echo ""
echo "Waiting for servers to reach SHUTDOWN state (timeout: ${DRAIN_TIMEOUT}s)..."

ALL_OK=true
while IFS= read -r line; do
    read -r name port uuid <<< "$line"
    printf "  Waiting for %s (%s)... " "$name" "$uuid"
    if _afl_poll_server_state "$uuid" "shutdown" "$DRAIN_TIMEOUT"; then
        echo "done"
    else
        echo "TIMEOUT"
        ALL_OK=false
    fi
done <<< "$SERVERS"

# Force kill any that didn't shut down gracefully
if [[ "$ALL_OK" == "false" ]]; then
    echo ""
    echo "Some servers did not shut down gracefully. Sending SIGKILL..."
    while IFS= read -r host; do
        [[ -z "$host" ]] && continue
        _afl_ssh "$host" "pgrep -f '$PATTERN' | xargs kill -9 2>/dev/null || true" || true
    done <<< "$UNIQUE_HOSTS"
    echo "Force kill sent."
fi

echo ""
echo "All done."
