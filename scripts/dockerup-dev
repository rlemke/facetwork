#!/usr/bin/env bash
# Start the ephemeral dev stack: MongoDB + PostGIS in Docker with
# /Volumes/afl_data mounted. DB data lives inside each container, so
# `--down` wipes everything cleanly.
#
# Usage:
#   scripts/dockerup-dev              # start (detached)
#   scripts/dockerup-dev --stop       # stop, keep containers (data survives)
#   scripts/dockerup-dev --down       # stop + remove containers (wipes DB data)
#   scripts/dockerup-dev --status     # show service status
#   scripts/dockerup-dev --logs       # tail logs
#
# Connection URLs (from host):
#   MongoDB:  mongodb://localhost:27017
#   PostGIS:  postgresql://afl:afl@localhost:5432/afl_gis
#
# Port overrides (via .env or shell):
#   AFL_DEV_MONGO_PORT    default 27017
#   AFL_DEV_POSTGIS_PORT  default 5432

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck source=_env.sh
[ -f "$SCRIPT_DIR/_env.sh" ] && source "$SCRIPT_DIR/_env.sh"

COMPOSE_FILE="$REPO_ROOT/docker-compose.dev.yml"

if [ ! -f "$COMPOSE_FILE" ]; then
    echo "ERROR: $COMPOSE_FILE not found" >&2
    exit 1
fi

cd "$REPO_ROOT"

case "${1:-up}" in
    --stop|stop)
        echo "Stopping dev stack (containers preserved, data survives) ..."
        docker compose -f "$COMPOSE_FILE" stop
        ;;
    --down|down)
        echo "Tearing down dev stack (containers removed, DB data WIPED) ..."
        docker compose -f "$COMPOSE_FILE" down
        ;;
    --status|status|ps)
        docker compose -f "$COMPOSE_FILE" ps
        ;;
    --logs|logs)
        docker compose -f "$COMPOSE_FILE" logs -f --tail=100
        ;;
    --help|-h|help)
        sed -n '2,20p' "$0"
        ;;
    *)
        echo "Starting dev stack (MongoDB + PostGIS, ephemeral) ..."
        docker compose -f "$COMPOSE_FILE" up -d
        echo ""
        echo "Dev stack is up:"
        echo "  MongoDB:  mongodb://localhost:${AFL_DEV_MONGO_PORT:-27017}"
        echo "  PostGIS:  postgresql://afl:afl@localhost:${AFL_DEV_POSTGIS_PORT:-5432}/afl_gis"
        echo ""
        echo "Stop with:  scripts/dockerup-dev --stop   (data survives)"
        echo "Tear down:  scripts/dockerup-dev --down   (wipes DB data)"
        ;;
esac
