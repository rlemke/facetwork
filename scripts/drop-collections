#!/usr/bin/env bash
# Empty all collections in the afl MongoDB database.
#
# Removes all documents from every AFL collection while preserving
# the collections themselves (and their indexes).
#
# Usage:
#   scripts/drop-collections                # interactive confirmation
#   scripts/drop-collections --yes          # skip confirmation
#   scripts/drop-collections --drop         # drop collections entirely (removes indexes too)
#   scripts/drop-collections --db NAME      # target a different database
#
set -euo pipefail

DATABASE="facetwork"
SKIP_CONFIRM=false
DROP_MODE=false

usage() {
    cat <<'EOF'
Usage: scripts/drop-collections [OPTIONS]

Empty all collections in the afl MongoDB database.

Options:
  --db NAME       Target database (default: afl)
  --yes, -y       Skip confirmation prompt
  --drop          Drop collections entirely (removes indexes too)
  -h, --help      Show this help message
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --db)           DATABASE="$2"; shift 2 ;;
        --yes|-y)       SKIP_CONFIRM=true; shift ;;
        --drop)         DROP_MODE=true; shift ;;
        -h|--help)      usage; exit 0 ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/_env.sh"

MONGO_URL="${AFL_MONGODB_URL:-mongodb://afl-mongodb:27017}"

# All AFL collections (matches MongoStore._ensure_indexes)
COLLECTIONS=(
    steps
    flows
    workflows
    runners
    tasks
    logs
    servers
    locks
    afl_sources
    step_logs
    handler_registrations
)

echo "=== Facetwork: Empty All Collections ==="
echo ""
echo "  Database:    $DATABASE"
echo "  Server:      $MONGO_URL"
echo "  Collections: ${#COLLECTIONS[@]}"
if [ "$DROP_MODE" = true ]; then
    echo "  Mode:        DROP (removes indexes)"
else
    echo "  Mode:        DELETE (preserves indexes)"
fi
echo ""

if [ "$SKIP_CONFIRM" = false ]; then
    read -r -p "This will delete ALL data in $DATABASE. Continue? [y/N] " response
    case "$response" in
        [yY][eE][sS]|[yY]) ;;
        *)
            echo "Aborted."
            exit 0
            ;;
    esac
    echo ""
fi

# Build the JavaScript commands
if [ "$DROP_MODE" = true ]; then
    JS_COMMANDS=""
    for coll in "${COLLECTIONS[@]}"; do
        JS_COMMANDS+="
var result = db.${coll}.drop();
print('  ${coll}: ' + (result ? 'dropped' : 'not found'));"
    done
else
    JS_COMMANDS=""
    for coll in "${COLLECTIONS[@]}"; do
        JS_COMMANDS+="
var result = db.${coll}.deleteMany({});
print('  ${coll}: ' + result.deletedCount + ' deleted');"
    done
fi

# Execute via mongosh (or fall back to mongo)
MONGO_CMD=""
if command -v mongosh &>/dev/null; then
    MONGO_CMD="mongosh"
elif command -v mongo &>/dev/null; then
    MONGO_CMD="mongo"
elif docker exec afl-mongodb mongosh --version &>/dev/null 2>&1; then
    # Try via external MongoDB container
    MONGO_CMD="docker exec afl-mongodb mongosh"
fi

if [ -z "$MONGO_CMD" ]; then
    echo "Error: mongosh/mongo not found locally and no afl-mongodb container reachable." >&2
    echo "Install mongosh or ensure MongoDB is running at afl-mongodb:27017" >&2
    exit 1
fi

echo "Clearing collections..."
echo ""

$MONGO_CMD --quiet "${MONGO_URL}/${DATABASE}" --eval "$JS_COMMANDS"

echo ""
echo "Done."
