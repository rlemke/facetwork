#!/usr/bin/env bash
# Install all system-level tools required for Facetwork development via Homebrew.
# Usage: scripts/install-tools [--minimal]
#
# --minimal  Install only core tools (skip geospatial/Java/Grafana)

set -euo pipefail

MINIMAL=false
if [[ "${1:-}" == "--minimal" ]]; then
    MINIMAL=true
fi

# --- Helpers ----------------------------------------------------------------

info()  { printf '\033[1;34m==> %s\033[0m\n' "$*"; }
ok()    { printf '\033[1;32m  ✓ %s\033[0m\n' "$*"; }
warn()  { printf '\033[1;33m  ! %s\033[0m\n' "$*"; }
fail()  { printf '\033[1;31m  ✗ %s\033[0m\n' "$*"; }

check() {
    if command -v "$1" &>/dev/null; then
        ok "$1 already installed ($(command -v "$1"))"
        return 0
    fi
    return 1
}

# --- Homebrew ---------------------------------------------------------------

info "Checking Homebrew"
if ! command -v brew &>/dev/null; then
    info "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
else
    ok "Homebrew already installed"
fi

# --- Taps -------------------------------------------------------------------

info "Adding Homebrew taps"
brew tap mongodb/brew 2>/dev/null || true

# --- Core tools -------------------------------------------------------------

info "Installing core tools"

# Python
check python3 || brew install python@3.12

# Node.js (for TypeScript agent SDK)
check node || brew install node

# Git
check git || brew install git

# Docker
check docker || brew install --cask docker

# Claude Code CLI
check claude || {
    info "Installing Claude Code..."
    npm install -g @anthropic-ai/claude-code
}

# --- Databases --------------------------------------------------------------

info "Installing database tools"

# MongoDB shell
check mongosh || brew install mongodb/brew/mongodb-community-shell

# PostgreSQL client (psql, pg_isready, etc.)
check psql || brew install libpq && brew link --force libpq

# --- Geospatial & optional tools -------------------------------------------

if [[ "$MINIMAL" == false ]]; then
    info "Installing geospatial tools"

    # osmium for OSM data processing
    check osmium || brew install osmium-tool

    # PostGIS (includes full PostgreSQL server)
    brew list postgis &>/dev/null && ok "postgis already installed" || brew install postgis

    # Java (for GraphHopper routing engine)
    check java || brew install openjdk@21

    # Grafana (operational monitoring)
    check grafana || brew install grafana
else
    warn "Skipping geospatial/Java/Grafana tools (--minimal mode)"
fi

# --- Python virtual environment + project setup -----------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
VENV_DIR="$PROJECT_DIR/.venv"

if [[ ! -d "$VENV_DIR" ]]; then
    info "Creating Python virtual environment at .venv"
    python3 -m venv "$VENV_DIR"
else
    ok "Virtual environment already exists at .venv"
fi

info "Installing Facetwork Python package into .venv"
"$VENV_DIR/bin/python" -m pip install --upgrade pip
"$VENV_DIR/bin/python" -m pip install -e "$PROJECT_DIR[dev,test,dashboard,mcp,mongodb]"

# --- Verify -----------------------------------------------------------------

info "Verifying installations"
FAILED=0

for cmd in python3 node git docker claude mongosh psql; do
    if command -v "$cmd" &>/dev/null; then
        ok "$cmd"
    else
        fail "$cmd not found"
        FAILED=$((FAILED + 1))
    fi
done

if [[ "$MINIMAL" == false ]]; then
    for cmd in osmium java grafana; do
        if command -v "$cmd" &>/dev/null; then
            ok "$cmd"
        else
            fail "$cmd not found"
            FAILED=$((FAILED + 1))
        fi
    done
fi

echo ""
if [[ "$FAILED" -eq 0 ]]; then
    info "All tools installed successfully"
else
    warn "$FAILED tool(s) failed to install — check output above"
fi

# --- Post-install notes -----------------------------------------------------

echo ""
info "Post-install notes:"
echo "  1. Activate the virtual environment:  source .venv/bin/activate"
echo "  2. If Docker was just installed, open Docker Desktop to finish setup"
echo "  3. Copy and edit .env:  cp .env.example .env"
echo "  4. Seed example workflows:  scripts/seed-examples"
echo "  5. Start the dashboard:  python -m facetwork.dashboard --log-format text"
echo ""
