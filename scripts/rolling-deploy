#!/usr/bin/env bash
# Rolling deploy: zero-downtime serial restart of remote AFL runners.
#
# For each server: drain (SIGTERM) → wait for SHUTDOWN → start new runner →
# wait for RUNNING → optionally health-check HTTP endpoint → move to next.
#
# Handlers are re-registered in MongoDB once before the rolling restart
# begins, so all runners pick up the latest handler code on restart.
#
# Usage:
#   scripts/rolling-deploy                                        # all examples, all servers
#   scripts/rolling-deploy --example hiv-drug-resistance          # specific handlers
#   scripts/rolling-deploy --host h1 --host h2                    # specific hosts
#   scripts/rolling-deploy --drain-timeout 90                     # custom drain wait
#   scripts/rolling-deploy -- --log-format text                   # extra runner args
#
# Options:
#   --example NAME      Register handlers from examples/NAME only (repeatable)
#   --host HOST         Target specific host (repeatable; default: all from MongoDB)
#   --drain-timeout N   Seconds to wait for graceful drain (default: 60)
#   --start-timeout N   Seconds to wait for new runner startup (default: 60)
#   --skip-registration Skip handler re-registration (handlers already up to date)
#   --                  Remaining args are passed to the runner service
#   -h, --help          Show this help message
#
# Environment:
#   AFL_RUNNER_HOSTS    Space-separated hostnames (fallback for host discovery)
#   AFL_REMOTE_PATH     Repo path on remote hosts (default: same as local)
#   AFL_SSH_OPTS        Extra SSH options
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Load shared env
source "$(dirname "$0")/_env.sh"
source "$(dirname "$0")/_remote.sh"
_afl_resolve_remote_env

PYTHON="${REPO_ROOT}/.venv/bin/python3"
[[ -x "$PYTHON" ]] || PYTHON=python3

EXAMPLES=()
RUNNER_ARGS=()
HOST_ARGS=()
DRAIN_TIMEOUT=60
START_TIMEOUT=60
SKIP_REGISTRATION=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --example)
            EXAMPLES+=("$2"); shift 2 ;;
        --host)
            HOST_ARGS+=("$2"); shift 2 ;;
        --drain-timeout)
            DRAIN_TIMEOUT="$2"; shift 2 ;;
        --start-timeout)
            START_TIMEOUT="$2"; shift 2 ;;
        --skip-registration)
            SKIP_REGISTRATION=true; shift ;;
        -h|--help)
            sed -n '2,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
            exit 0 ;;
        --)
            shift; RUNNER_ARGS=("$@"); break ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1 ;;
    esac
done

echo "=== Facetwork: Rolling Deploy ==="
echo ""
echo "  Drain timeout:  ${DRAIN_TIMEOUT}s"
echo "  Start timeout:  ${START_TIMEOUT}s"
echo ""

# =========================================================================
# Step 1: Re-register handlers (centralized, done once)
# =========================================================================

if [[ "$SKIP_REGISTRATION" == "false" ]]; then
    # Default: all examples that have handlers/__init__.py
    if [[ ${#EXAMPLES[@]} -eq 0 ]]; then
        for init in "$REPO_ROOT"/examples/*/handlers/__init__.py; do
            example_dir="$(dirname "$(dirname "$init")")"
            EXAMPLES+=("$(basename "$example_dir")")
        done
    fi

    echo "--- Re-registering handlers ---"
    echo "  Examples: ${EXAMPLES[*]}"
    echo ""

    env PYTHONPATH="$REPO_ROOT" "$PYTHON" -c "
import sys, os

repo = os.environ.get('REPO_ROOT', '$REPO_ROOT')
examples = '${EXAMPLES[*]}'.split()

from facetwork.runtime.mongo_store import MongoStore
from facetwork.runtime import RegistryRunner, RegistryRunnerConfig, Evaluator, Telemetry

mongo_url = os.environ.get('AFL_MONGODB_URL', 'mongodb://afl-mongodb:27017')
store = MongoStore(mongo_url)
telemetry = Telemetry()
evaluator = Evaluator(store, telemetry)
runner = RegistryRunner(store, evaluator)

# Registrations use upsert (save_handler_registration) so no need to
# wipe the collection — existing entries are updated in place and
# registrations from other sources (Docker agents, etc.) are preserved.
print('Registering handlers (upsert)...')
print()

total = 0
for name in examples:
    example_dir = os.path.join(repo, 'examples', name)
    handlers_dir = os.path.join(example_dir, 'handlers')
    if not os.path.isdir(handlers_dir):
        print(f'  {name}: SKIP (no handlers/)')
        continue
    if example_dir not in sys.path:
        sys.path.insert(0, example_dir)
    try:
        if 'handlers' in sys.modules:
            del sys.modules['handlers']
        to_remove = [k for k in sys.modules if k.startswith('handlers.')]
        for k in to_remove:
            del sys.modules[k]
        from handlers import register_all_registry_handlers
        before = store._db.handler_registrations.count_documents({})
        register_all_registry_handlers(runner)
        after = store._db.handler_registrations.count_documents({})
        count = after - before
        total += count
        print(f'  {name}: {count} handlers registered')
    except Exception as e:
        print(f'  {name}: ERROR — {e}')
    finally:
        if example_dir in sys.path:
            sys.path.remove(example_dir)

print()
print(f'Total: {total} handlers registered')
print()
"
else
    echo "Skipping handler registration (--skip-registration)."
    echo ""
fi

# =========================================================================
# Step 2: Discover running servers
# =========================================================================

echo "--- Discovering running servers ---"

SERVERS=$(_afl_query_running_servers)

if [[ -z "$SERVERS" ]]; then
    echo "No running servers found in MongoDB. Nothing to deploy."
    exit 0
fi

# If --host specified, filter to those hosts
if [[ ${#HOST_ARGS[@]} -gt 0 ]]; then
    FILTERED=""
    for host in "${HOST_ARGS[@]}"; do
        MATCH=$(echo "$SERVERS" | grep "^${host} " || true)
        if [[ -n "$MATCH" ]]; then
            FILTERED="${FILTERED}${FILTERED:+$'\n'}${MATCH}"
        else
            echo "Warning: no running server found for host '$host'"
        fi
    done
    SERVERS="$FILTERED"
fi

if [[ -z "$SERVERS" ]]; then
    echo "No matching servers to deploy."
    exit 0
fi

# Count servers
SERVER_COUNT=$(echo "$SERVERS" | wc -l | tr -d ' ')

echo "  Found $SERVER_COUNT server(s) to restart:"
echo "$SERVERS" | while IFS= read -r line; do
    read -r name port uuid <<< "$line"
    echo "    $name (port=$port, id=$uuid)"
done
echo ""

# Build runner args string for SSH
RUNNER_ARGS_STR=""
if [[ ${#RUNNER_ARGS[@]} -gt 0 ]]; then
    for arg in "${RUNNER_ARGS[@]}"; do
        RUNNER_ARGS_STR="$RUNNER_ARGS_STR $(printf '%q' "$arg")"
    done
fi

PATTERN='afl\.runtime\.runner'

# =========================================================================
# Step 3: Rolling restart — one server at a time
# =========================================================================

echo "--- Starting rolling restart ---"
echo ""

CURRENT=0
FAILED=false

while IFS= read -r line; do
    read -r srv_name srv_port srv_uuid <<< "$line"
    CURRENT=$((CURRENT + 1))

    echo "[$CURRENT/$SERVER_COUNT] Restarting $srv_name (id=$srv_uuid)..."

    # --- Drain ---
    echo "  Draining $srv_name..."
    _afl_ssh "$srv_name" "pgrep -f '$PATTERN' | xargs kill 2>/dev/null || true" || {
        echo "  ERROR: SSH to $srv_name failed for drain"
        FAILED=true
        echo "  ABORTING rolling deploy — remaining servers untouched."
        break
    }

    printf "  Waiting for SHUTDOWN state (timeout: %ss)... " "$DRAIN_TIMEOUT"
    if _afl_poll_server_state "$srv_uuid" "shutdown" "$DRAIN_TIMEOUT"; then
        echo "done"
    else
        echo "TIMEOUT"
        echo "  ERROR: $srv_name did not reach SHUTDOWN state within ${DRAIN_TIMEOUT}s"
        FAILED=true
        echo "  ABORTING rolling deploy — remaining servers untouched."
        break
    fi

    # Optionally verify via HTTP health endpoint
    if [[ "$srv_port" -gt 0 ]]; then
        # Health endpoint should be unreachable after drain
        if curl -sf --connect-timeout 2 "http://${srv_name}:${srv_port}/health" >/dev/null 2>&1; then
            echo "  Warning: HTTP health endpoint still responding after drain"
        fi
    fi

    # --- Start new runner ---
    echo "  Starting new runner on $srv_name..."
    _afl_ssh "$srv_name" \
        "cd $AFL_REMOTE_PATH && nohup scripts/runner --registry$RUNNER_ARGS_STR > /tmp/afl-runner-\$\$.log 2>&1 &" || {
        echo "  ERROR: SSH to $srv_name failed for start"
        FAILED=true
        echo "  ABORTING rolling deploy — $srv_name is DOWN, remaining servers untouched."
        break
    }

    printf "  Waiting for new runner to register (timeout: %ss)... " "$START_TIMEOUT"
    NEW_LINE=""
    NEW_LINE=$(_afl_poll_new_server "$srv_name" "running" "$START_TIMEOUT" "$srv_uuid") || {
        echo "TIMEOUT"
        echo "  ERROR: new runner on $srv_name did not register within ${START_TIMEOUT}s"
        FAILED=true
        echo "  ABORTING rolling deploy — $srv_name may be DOWN, remaining servers untouched."
        break
    }
    echo "done"

    # Verify via HTTP health endpoint if port is known
    read -r new_name new_port new_uuid <<< "$NEW_LINE"
    if [[ "$new_port" -gt 0 ]]; then
        printf "  Health-checking http://%s:%s/health... " "$new_name" "$new_port"
        # Retry a few times — server may need a moment after registration
        HEALTH_OK=false
        for attempt in $(seq 1 5); do
            if curl -sf --connect-timeout 2 "http://${new_name}:${new_port}/health" >/dev/null 2>&1; then
                HEALTH_OK=true
                break
            fi
            sleep 1
        done
        if [[ "$HEALTH_OK" == "true" ]]; then
            echo "ok"
        else
            echo "FAILED (non-fatal, server registered in MongoDB)"
        fi
    fi

    echo "  $srv_name restarted (new id=$new_uuid)"
    echo ""

done <<< "$SERVERS"

# =========================================================================
# Summary
# =========================================================================

echo "--- Rolling deploy summary ---"
if [[ "$FAILED" == "true" ]]; then
    echo "  INCOMPLETE: deploy was aborted after a failure."
    echo "  $CURRENT of $SERVER_COUNT server(s) were processed."
    echo "  Check remote logs and server states before retrying."
    exit 1
else
    echo "  SUCCESS: all $SERVER_COUNT server(s) restarted."
    echo ""
    echo "Current running servers:"
    _afl_query_running_servers | while IFS= read -r line; do
        read -r name port uuid <<< "$line"
        echo "  $name (port=$port, id=$uuid)"
    done
fi
