#!/usr/bin/env bash
# Register handlers for examples, then start the runner and dashboard.
#
# Local mode (default): upserts handler_registrations from one or more
# examples, starts the dashboard (port 8080), and starts the runner
# service in registry mode.
#
# Remote mode: registers handlers locally (MongoDB), then SSHs to each
# remote host to start runner processes, polling MongoDB for RUNNING state.
#
# Usage:
#   scripts/start-runner                                        # register ALL examples
#   scripts/start-runner --example hiv-drug-resistance          # one example
#   scripts/start-runner --example devops-deploy --example hiv-drug-resistance
#   scripts/start-runner --no-dashboard                         # skip dashboard
#   scripts/start-runner -- --log-format text                   # extra args passed to runner
#   scripts/start-runner --instances 3                          # 3 concurrent runner processes
#   scripts/start-runner --example hiv-drug-resistance -- --log-format text --max-concurrent 10
#
# Remote mode:
#   scripts/start-runner --all --example hiv-drug-resistance    # all AFL_RUNNER_HOSTS
#   scripts/start-runner --host h1 --host h2 --example hiv-drug-resistance
#
# Options:
#   --example NAME   Register handlers from examples/NAME only (repeatable)
#   --instances N    Start N runner processes per host (default: 1)
#   --no-dashboard   Do not start the dashboard
#   --all            Start on all hosts from AFL_RUNNER_HOSTS
#   --host HOST      Start on specific remote host (repeatable)
#   --start-timeout N  Seconds to wait for remote runner startup (default: 30)
#   --              Remaining args are passed to the runner service
#   -h, --help      Show this help message
#
# Environment (remote mode):
#   AFL_RUNNER_HOSTS   Space-separated hostnames
#   AFL_REMOTE_PATH    Repo path on remote hosts (default: same as local)
#   AFL_SSH_OPTS       Extra SSH options
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Load shared env (.env sets AFL_MONGODB_URL etc.)
source "$(dirname "$0")/_env.sh"

PYTHON="${REPO_ROOT}/.venv/bin/python3"
[[ -x "$PYTHON" ]] || PYTHON=python3

EXAMPLES=()
RUNNER_ARGS=()
INSTANCES=1
DASHBOARD=true
MODE="local"
HOST_ARGS=()
START_TIMEOUT=30

while [[ $# -gt 0 ]]; do
    case "$1" in
        --example)
            EXAMPLES+=("$2"); shift 2 ;;
        --instances)
            INSTANCES="$2"; shift 2 ;;
        --no-dashboard)
            DASHBOARD=false; shift ;;
        --all)
            MODE="remote"; shift ;;
        --host)
            MODE="remote"; HOST_ARGS+=("$2"); shift 2 ;;
        --start-timeout)
            START_TIMEOUT="$2"; shift 2 ;;
        -h|--help)
            sed -n '2,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
            exit 0 ;;
        --)
            shift; RUNNER_ARGS=("$@"); break ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Usage: scripts/start-runner [--example NAME]... [--instances N] [--no-dashboard] [--all | --host HOST]... [-- RUNNER_ARGS...]" >&2
            exit 1 ;;
    esac
done

if ! [[ "$INSTANCES" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: --instances must be a positive integer, got '$INSTANCES'" >&2
    exit 1
fi

# Default: all examples that have handlers/__init__.py
if [[ ${#EXAMPLES[@]} -eq 0 ]]; then
    for init in "$REPO_ROOT"/examples/*/handlers/__init__.py; do
        example_dir="$(dirname "$(dirname "$init")")"
        EXAMPLES+=("$(basename "$example_dir")")
    done
fi

# Source example-specific runner.env files (e.g. examples/osm-geocoder/runner.env).
# These can override global defaults like AFL_TASK_EXECUTION_TIMEOUT_MS for
# examples with specific runtime requirements (long imports, etc.).
for ex in "${EXAMPLES[@]}"; do
    runner_env="$REPO_ROOT/examples/$ex/runner.env"
    if [[ -f "$runner_env" ]]; then
        # shellcheck source=/dev/null
        set -a; source "$runner_env"; set +a
    fi
done

echo "=== Facetwork: Register Handlers & Start Runner ==="
echo ""
echo "  Examples:  ${EXAMPLES[*]}"
echo "  Instances: $INSTANCES"
echo "  Dashboard: $DASHBOARD"
echo "  Mode:      $MODE"
if [[ -n "${AFL_TASK_EXECUTION_TIMEOUT_MS:-}" ]]; then
    echo "  Exec timeout: ${AFL_TASK_EXECUTION_TIMEOUT_MS}ms"
fi
if [[ -n "${AFL_STUCK_TIMEOUT_MS:-}" ]]; then
    echo "  Stuck timeout: ${AFL_STUCK_TIMEOUT_MS}ms"
fi
echo ""

# Register handlers via inline Python
env PYTHONPATH="$REPO_ROOT" "$PYTHON" -c "
import sys, os

repo = os.environ.get('REPO_ROOT', '$REPO_ROOT')
examples = '${EXAMPLES[*]}'.split()

from facetwork.runtime.mongo_store import MongoStore
from facetwork.runtime import RegistryRunner, RegistryRunnerConfig, Evaluator, Telemetry

mongo_url = os.environ.get('AFL_MONGODB_URL', 'mongodb://afl-mongodb:27017')
store = MongoStore(mongo_url)
telemetry = Telemetry()
evaluator = Evaluator(store, telemetry)
runner = RegistryRunner(store, evaluator)

# Registrations use upsert (save_handler_registration) so no need to
# wipe the collection — existing entries are updated in place and
# registrations from other sources (Docker agents, etc.) are preserved.
print('Registering handlers (upsert)...')
print()

total = 0
for name in examples:
    example_dir = os.path.join(repo, 'examples', name)
    handlers_dir = os.path.join(example_dir, 'handlers')
    if not os.path.isdir(handlers_dir):
        print(f'  {name}: SKIP (no handlers/)')
        continue

    # Add example dir to path so 'handlers' package resolves
    if example_dir not in sys.path:
        sys.path.insert(0, example_dir)

    # Import and call register_all_registry_handlers
    try:
        # Fresh import each time
        if 'handlers' in sys.modules:
            del sys.modules['handlers']
        # Also clear submodules to avoid cross-example pollution
        to_remove = [k for k in sys.modules if k.startswith('handlers.')]
        for k in to_remove:
            del sys.modules[k]

        from handlers import register_all_registry_handlers
        before = store._db.handler_registrations.count_documents({})
        register_all_registry_handlers(runner)
        after = store._db.handler_registrations.count_documents({})
        count = after - before
        total += count
        print(f'  {name}: {count} handlers registered')
    except Exception as e:
        print(f'  {name}: ERROR — {e}')
    finally:
        # Clean up for next example
        if example_dir in sys.path:
            sys.path.remove(example_dir)

print()
print(f'Total: {total} handlers registered')
print()
"

# Build PYTHONPATH that includes all example directories so the runner
# can load handler modules from any registered example.
RUNNER_PYTHONPATH="$REPO_ROOT"
for ex in "${EXAMPLES[@]}"; do
    ex_dir="$REPO_ROOT/examples/$ex"
    if [[ -d "$ex_dir/handlers" ]]; then
        RUNNER_PYTHONPATH="$RUNNER_PYTHONPATH:$ex_dir"
    fi
done

# =========================================================================
# Local mode
# =========================================================================

if [[ "$MODE" == "local" ]]; then
    PIDS=()

    # Start dashboard
    if [[ "$DASHBOARD" == "true" ]]; then
        echo "Starting dashboard on port 8080..."
        env PYTHONPATH="$REPO_ROOT" PYTHONUNBUFFERED=1 "$PYTHON" -m facetwork.dashboard &
        PIDS+=($!)
        echo "  Dashboard started (PID $!)"
        # Wait for dashboard to bind port before starting runners
        # (runners also have HTTP status servers that auto-increment ports)
        for _i in $(seq 1 20); do
            if curl -sf http://localhost:8080/health >/dev/null 2>&1; then
                break
            fi
            sleep 0.5
        done
    fi

    # Start runner(s)
    if [[ "$INSTANCES" -eq 1 && "$DASHBOARD" == "false" ]]; then
        echo "Starting runner with --registry..."
        exec env PYTHONPATH="$RUNNER_PYTHONPATH" PYTHONUNBUFFERED=1 "$PYTHON" -m facetwork.runtime.runner --registry ${RUNNER_ARGS[@]+"${RUNNER_ARGS[@]}"}
    else
        echo "Starting $INSTANCES runner instance(s) with --registry..."
        for i in $(seq 1 "$INSTANCES"); do
            env PYTHONPATH="$RUNNER_PYTHONPATH" PYTHONUNBUFFERED=1 "$PYTHON" -m facetwork.runtime.runner --registry ${RUNNER_ARGS[@]+"${RUNNER_ARGS[@]}"} &
            PIDS+=($!)
            echo "  Runner $i started (PID $!)"
        done
    fi

    echo ""
    echo "All processes started. PIDs: ${PIDS[*]}"
    echo "Use scripts/stop-runners to stop them."

    # Wait for all — if any exits, report it
    wait "${PIDS[@]}"
    exit 0
fi

# =========================================================================
# Remote mode
# =========================================================================

source "$(dirname "$0")/_remote.sh"
_afl_resolve_remote_env

HOSTS=()
while IFS= read -r h; do
    HOSTS+=("$h")
done < <(_afl_resolve_hosts "${HOST_ARGS[@]}")

echo "=== Starting Remote Runners ==="
echo "  Hosts: ${HOSTS[*]}"
echo "  Remote path: $AFL_REMOTE_PATH"
echo ""

# Build the runner args string for SSH
RUNNER_ARGS_STR=""
if [[ ${#RUNNER_ARGS[@]} -gt 0 ]]; then
    # Quote each arg for remote shell
    for arg in "${RUNNER_ARGS[@]}"; do
        RUNNER_ARGS_STR="$RUNNER_ARGS_STR $(printf '%q' "$arg")"
    done
fi

ALL_OK=true

for host in "${HOSTS[@]}"; do
    echo "Starting runner on $host..."

    # Record existing server UUIDs on this host so we can detect the new one
    EXISTING_UUIDS=()
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        read -r srv_name srv_port srv_uuid <<< "$line"
        if [[ "$srv_name" == "$host" ]]; then
            EXISTING_UUIDS+=("$srv_uuid")
        fi
    done <<< "$(_afl_query_running_servers)"

    # Start runner on remote host (detached via nohup)
    for i in $(seq 1 "$INSTANCES"); do
        _afl_ssh "$host" \
            "cd $AFL_REMOTE_PATH && nohup scripts/runner --registry$RUNNER_ARGS_STR > /tmp/afl-runner-\$\$.log 2>&1 &" || {
            echo "  ERROR: SSH to $host failed"
            ALL_OK=false
            continue 2
        }
    done

    # Poll MongoDB until new server(s) appear with state=running
    printf "  Waiting for runner on %s to register (timeout: %ss)... " "$host" "$START_TIMEOUT"
    if _afl_poll_new_server "$host" "running" "$START_TIMEOUT" "${EXISTING_UUIDS[@]+"${EXISTING_UUIDS[@]}"}"; then
        echo "done"
    else
        echo "TIMEOUT"
        ALL_OK=false
    fi
done

echo ""
if [[ "$ALL_OK" == "true" ]]; then
    echo "All remote runners started successfully."
else
    echo "Some runners failed to start. Check logs on the remote hosts."
    exit 1
fi
